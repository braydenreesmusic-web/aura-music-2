# Frontend (Vite)
# Set this on your frontend host (Vercel/Netlify/Cloudflare Pages).
# Example: https://api.yourees.com/api
VITE_API_BASE_URL="https://api.your-domain.com/api"

# Backend (Express)
# Server port is auto-assigned by many hosts; keep default for local dev.
PORT=3001

# Optional: explicit node environment for backend host
NODE_ENV="production"
